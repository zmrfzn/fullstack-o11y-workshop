#!/bin/bash

# Check 1: NR Browser snippet present in index.html source
if ! grep -q "NREUM" /root/pern-newrelic/packages/frontend/index.html 2>/dev/null; then
  echo "New Relic Browser snippet not found in packages/frontend/index.html. Paste the snippet from New Relic into the <head> section and save."
  exit 1
fi

# Check 2: Backend is serving the API (Vite dev server proxies to it)
if ! curl -sf http://localhost:8080/api/tutorials > /dev/null 2>&1; then
  echo "Backend is not running on port 8080. Check the Node Terminal tab."
  exit 1
fi

echo "Browser agent snippet is in place and the backend is running."
exit 0
